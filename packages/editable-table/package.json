{
    "name": "@react-editable-tables/native",
    "version": "0.1.2",
    "description": "轻量、零依赖的 React 可编辑表格，内置虚拟滚动、校验、数据联动和 CSS 变量主题",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./style.css": "./dist/index.css"
    },
    "files": [
        "dist"
    ],
    "sideEffects": [
        "*.css"
    ],
    "scripts": {
        "build": "tsup",
        "prepublishOnly": "pnpm run build",
        "type-check": "tsc --noEmit",
        "test": "vitest",
        "coverage": "vitest run --coverage"
    },
    "keywords": [
        "react",
        "editable-table",
        "table",
        "virtual-scroll",
        "formily"
    ],
    "author": "chenJJ-88",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/chenJJ-88/react-editable-tables.git",
        "directory": "packages/editable-table"
    },
    "homepage": "https://chenjj-88.github.io/react-editable-tables/",
    "bugs": {
        "url": "https://github.com/chenJJ-88/react-editable-tables/issues"
    },
    "peerDependencies": {
        "react": ">=17",
        "react-dom": ">=17"
    },
    "dependencies": {
        "@tanstack/react-virtual": "^3.13.9"
    },
    "devDependencies": {
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^14.3.1",
        "@testing-library/user-event": "^14.6.1",
        "@types/react": "^18.3.0",
        "@types/react-dom": "^18.3.0",
        "jsdom": "^25.0.1",
        "typescript": "~5.8.3",
        "vitest": "^3.1.1"
    }
}
