{
    "name": "@react-editable-tables/formily",
    "version": "0.1.2",
    "description": "高性能可编辑表格组件，基于 Formily 2.x + antd 5.x",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "sideEffects": [
        "src/style.ts",
        "dist/*"
    ],
    "scripts": {
        "build": "tsup",
        "prepublishOnly": "pnpm run build",
        "type-check": "tsc --noEmit",
        "test": "vitest",
        "coverage": "vitest run --coverage"
    },
    "keywords": [
        "react",
        "editable-table",
        "formily",
        "antd",
        "table"
    ],
    "author": "chenJJ-88",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/chenJJ-88/react-editable-tables.git",
        "directory": "packages/fast-editable-table"
    },
    "homepage": "https://chenjj-88.github.io/react-editable-tables/",
    "bugs": {
        "url": "https://github.com/chenJJ-88/react-editable-tables/issues"
    },
    "peerDependencies": {
        "react": ">=17",
        "react-dom": ">=17",
        "antd": ">=5",
        "@formily/core": ">=2",
        "@formily/react": ">=2",
        "@formily/reactive": ">=2"
    },
    "devDependencies": {
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "antd": "^5.22.0",
        "@formily/core": "^2.3.1",
        "@formily/react": "^2.3.1",
        "@formily/reactive": "^2.3.1",
        "@types/react": "^18.3.0",
        "@types/react-dom": "^18.3.0",
        "typescript": "~6.0.3",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^14.3.1",
        "@testing-library/user-event": "^14.6.1",
        "jsdom": "^25.0.1",
        "vitest": "^3.1.1"
    }
}
